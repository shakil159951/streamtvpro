{
  "rewrites": [
    { "source": "/api/proxy", "destination": "/api/proxy" },
    { "source": "/api/channels", "destination": "/api/channels" },
    { "source": "/api/playlists", "destination": "/api/playlists" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS, HEAD" },
        { "key": "Access-Control-Allow-Headers", "value": "Origin, X-Requested-With, Content-Type, Accept, Range, Authorization" }
      ]
    }
  ]
}
